# ── Meta WhatsApp Business Cloud API ──────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# ── Anthropic Claude API ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Admin API Key (for /broadcast and /admin/* endpoints) ─────────────────────
ADMIN_API_KEY=your_secure_random_admin_key_here

# ── Database (optional — defaults to local SQLite) ─────────────────────────────
DATABASE_URL=sqlite:///./whatsapp_agent.db
