# Sneakers Fest — Environment Variables
# Copy to .env.local for local dev, set on Netlify for production

# ── Paystack (get keys from dashboard.paystack.com) ───────
# Test key starts with pk_test_, live key with pk_live_
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Flutterwave (get keys from dashboard.flutterwave.com) ───
# Test key starts with FLWPUBK_TEST-, live key with FLWPUBK-
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# ── AI Backend (rembg + Whisper) ──────────────────
# Leave empty to show "offline" message gracefully
VITE_BACKEND_URL=

# ── Ollama (Local LLM / AI Chat) ─────────────────
# Leave empty to show "offline" message gracefully
VITE_OLLAMA_URL=
VITE_OLLAMA_MODEL=llama3.2

# ── Listmonk (Newsletter) ─────────────────────────
# Leave empty to show "not configured" message gracefully
VITE_LISTMONK_URL=
VITE_LISTMONK_LIST_UUID=

# ── Production (update these when deploying to a VPS) ──
# VITE_BACKEND_URL=https://api.yourdomain.com
# VITE_OLLAMA_URL=https://ollama.yourdomain.com
# VITE_LISTMONK_URL=https://newsletter.yourdomain.com
