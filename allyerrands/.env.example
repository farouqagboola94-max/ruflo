# ============================================================
# Za.allyErrands — Environment Variables
# Copy this to .env and fill in every value.
# NEVER commit the real .env to git.
# ============================================================

# ── Supabase (Project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Make.com webhooks
# Scenario 1: fires on every new request (admin standby alert)
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/YOUR_TOKEN_SCENARIO_1
# Scenario 2: fires when payment is confirmed (DISPATCH NOW alert)
MAKE_PAID_WEBHOOK_URL=https://hook.eu2.make.com/YOUR_TOKEN_SCENARIO_2

# ── Flutterwave (flutterwave.com > Dashboard > Settings > API)
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx
# The "Secret Hash" you set in FLW Dashboard > Settings > Webhooks
FLW_WEBHOOK_SECRET=your_custom_secret_hash_here

# ── WhatsApp Business API (Meta for Developers)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890

# ── Site URL (used for redirect_url in Flutterwave payment link)
SITE_URL=https://zallyerrands.com
