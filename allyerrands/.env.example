# ============================================================
# Za.allyErrands — Environment Variables
# Copy this to .env and fill in every value before deploying.
# NEVER commit your real .env to git.
# ============================================================

# ── Supabase (get these from Project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Make.com (generated when you create a Webhooks trigger)
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/YOUR_UNIQUE_TOKEN

# ── WhatsApp Business API (Meta for Developers)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890

# ── Site (used by the portal to know which Supabase project to call)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
